    <string name="voicevox_terms_title">Nutzungsbedingungen von VOICEVOX</string>
    <string name="voicevox_terms_description">Um VOICEVOX nutzen zu können, müssen Sie den Nutzungsbedingungen zustimmen. Audiodaten werden mithilfe von Open-Source-Bibliotheken generiert.</string>
    <string name="voicevox_view_terms">Einzelheiten zu den Nutzungsbedingungen finden Sie hier</string>
